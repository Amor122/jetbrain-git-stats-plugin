<idea-plugin version="2">
    <id>com.gitstats</id>
    <name>GitStats</name>
    <version>1.0.0</version>
    <vendor>GitStats</vendor>
    <description>Show code change statistics for git commits including lines added, removed, and binary file changes.</description>
    <idea-version since-build="211" until-build="999.*" />
    <depends>com.intellij.modules.platform</depends>
    <depends>Git4Idea</depends>

    <actions>
        <group id="GitStats.ToolsMenu" text="Git Commit Statistics" description="Git Commit Statistics">
            <add-to-group group-id="ToolsMenu" anchor="last" />
            <action id="GitStats.ViewStats"
                    class="com.gitstats.GitCommitStatsAction"
                    text="View by Hash..."
                    description="Show code change statistics for git commits">
            </action>
        </group>
        <group id="GitStats.MainMenu" text="Git Commit Statistics" description="Git Commit Statistics">
            <add-to-group group-id="MainMenu" anchor="last" />
            <action id="GitStats.ViewStats2"
                    class="com.gitstats.GitCommitStatsAction"
                    text="View by Hash..."
                    description="Show code change statistics for git commits">
            </action>
        </group>
    </actions>
</idea-plugin>
